{
	"name": "nia-cli",
	"version": "0.0.3",
	"type": "module",
	"description": "CLI for the Nia — search code, docs, and research from the terminal",
	"packageManager": "bun@1.3.10",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/nozomio-labs/nia-cli.git"
	},
	"bugs": {
		"url": "https://github.com/nozomio-labs/nia-cli/issues"
	},
	"homepage": "https://github.com/nozomio-labs/nia-cli#readme",
	"keywords": [
		"cli",
		"nia",
		"search",
		"developer-tools"
	],
	"engines": {
		"bun": ">=1.3.10"
	},
	"publishConfig": {
		"access": "public"
	},
	"files": [
		"dist"
	],
	"bin": {
		"nia": "dist/cli"
	},
	"scripts": {
		"dev": "bun run src/cli.ts",
		"build": "crust build",
		"start": "./dist/cli",
		"check:types": "tsc --noEmit",
		"test": "bun test",
		"check": "biome check ."
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.6",
		"@changesets/cli": "^2.30.0",
		"@crustjs/core": "0.0.12",
		"@crustjs/crust": "0.0.17",
		"@crustjs/plugins": "0.0.15",
		"@crustjs/prompts": "^0.0.8",
		"@crustjs/skills": "^0.0.15",
		"@crustjs/store": "^0.0.4",
		"@crustjs/style": "^0.0.4",
		"@types/bun": "^1.3.10",
		"nia-ai-ts": "^0.1.0",
		"typescript": "^5.9.3"
	}
}
